# Copy to deploy/homelab/env/api.env
# DATABASE_URL is set in docker-compose.yml from Postgres service vars.

NODE_ENV=production
PORT=4000

JWT_SECRET=replace-with-32-char-minimum-secret
JWT_EXPIRES_IN=1h
CORTEX_ENCRYPTION_KEY=replace-with-32-char-minimum-secret

# Browser origins (Tailscale IP, MagicDNS, or LAN). No trailing slash.
CORTEX_FRONTEND_URL=http://127.0.0.1:8080
# Comma-separated UI origins — include every host you open Cortex on (127.0.0.1, Tailscale, Pi-hole DNS).
# With HOMELAB_DNS_DOMAIN=cortex also allow http://cortex.cortex:8080 (API auto-adds this when rebuilt).
CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080,http://cortex.cortex:8080
# Optional fixed OAuth redirect (if unset, redirect follows returnOrigin from Mail connect):
# GOOGLE_REDIRECT_URI=http://127.0.0.1:8080/api/gmail/oauth/callback

# OAuth redirect URIs must match Google/Spotify/etc. console entries and hit your API (homelab: nginx :8080)
# GOOGLE_REDIRECT_URI=http://127.0.0.1:8080/api/gmail/oauth/callback
# CORTEX_FRONTEND_URL=http://127.0.0.1:8080
# SPOTIFY_REDIRECT_URI=http://100.x.x.x:4000/api/spotify/oauth/callback
# MICROSOFT_REDIRECT_URI=http://100.x.x.x:4000/api/microsoft/oauth/callback
# Outlook / Microsoft 365 mail (see docs/microsoft-oauth-homelab.md):
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# NOTION_REDIRECT_URI=http://100.x.x.x:4000/api/notion/oauth/callback

# Optional integrations (see backend/.env.example)
# AI — Claude Pro/Max does NOT include API access; use console.anthropic.com for billing.
# ANTHROPIC_API_KEY=
# Kimi / Moonshot (used first when set — mail, Spotify AI DJ, chat):
# KIMI_API_KEY=sk-...
# MOONSHOT_API_KEY=   # alias for KIMI_API_KEY
# KIMI_MODEL=kimi-k2.6
# KIMI_BASE_URL=https://api.moonshot.cn/v1   # or .ai for international keys
# OPENAI_API_KEY=
# Local Ollama (free — API container reaches host via host.docker.internal):
# Local Ollama on homelab host:
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# Remote Ollama on gaming PC (Tailscale) — Cortex auto-detects on/off:
# OLLAMA_BASE_URL=http://100.x.x.x:11434
# OLLAMA_MODEL=gemma4:12b
# OLLAMA_PC_NAME=Grey PC
# OLLAMA_CHECK_MS=30000

# --- Email OTP login (pick one) ---
# Real mail (Gmail: use an App Password, not your account password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-16-char-app-password
#
# Self-hosted without SMTP — show code in login UI (local PC / tailnet only):
CORTEX_OTP_DEV_FALLBACK=1

# Obsidian vault (bind-mount host path in docker-compose — see OBSIDIAN_VAULT_HOST_PATH)
OBSIDIAN_VAULT_PATH=/vault
OBSIDIAN_VAULT_NAME=greyhill_brain
OBSIDIAN_AI_LOG_ENABLED=true
OBSIDIAN_USE_CLI=false

# Cross-session agent memory (host service on :3111 — npm run server:memory:setup)
AGENTMEMORY_URL=http://host.docker.internal:3111
AGENTMEMORY_PROJECT=cortex
# AGENTMEMORY_SECRET=
# AGENTMEMORY_AUTO_REMEMBER=false

# Do not set demo user vars in production homelab unless intentional.

# --- Homelab dashboard (GET /api/homelab/status) ---
# Tailnet IP or LAN host for Jellyfin/Nextcloud/Grafana health probes
# HOMELAB_SERVICE_HOST=100.x.x.x
# Pi-hole local names (npm run nas:pihole:local-dns): jellyfin.cortex, api.cortex, …
# HOMELAB_DNS_DOMAIN=cortex
# From Docker API container, reach host Prometheus:
# HOMELAB_PROMETHEUS_URL=http://host.docker.internal:9090
# HOMELAB_GRAFANA_URL=http://100.x.x.x:3000
# HOMELAB_JELLYFIN_URL=http://100.x.x.x:8096
# HOMELAB_NEXTCLOUD_URL=http://100.x.x.x:8081
# HOMELAB_IMMICH_URL=http://100.x.x.x:2283
# HOMELAB_PIHOLE_URL=http://100.x.x.x:8090
# From Docker API container (same as NEXTCLOUD_URL pattern):
# HOMELAB_PIHOLE_URL=http://host.docker.internal:8090
# HOMELAB_PIHOLE_API_PASSWORD=same-as-pihole-admin-password
# HOMELAB_ICLOUD_APPLE_ID=you@icloud.com
# HOMELAB_PORTAINER_URL=https://100.x.x.x:9443

# Nextcloud WebDAV (Cortex Cloud tab) — from Docker API use host.docker.internal
# NEXTCLOUD_URL=http://host.docker.internal:8081
# NEXTCLOUD_USERNAME=admin
# NEXTCLOUD_PASSWORD=your-nextcloud-admin-password
# Or app password (preferred): NEXTCLOUD_APP_PASSWORD=
# NAS root mounted read-only at /nas in cortex-api (set NAS_DATA_ROOT in deploy/homelab/.env)
# HOMELAB_NAS_ROOT=/nas

# Homelab UI redeploy button (generated by npm run server:deploy:setup)
# CORTEX_DEPLOY_TOKEN=   # in deploy/homelab/.env; synced to HOMELAB_DEPLOY_TOKEN here
# HOMELAB_DEPLOY_TOKEN=
# HOMELAB_DEPLOY_LISTENER_URL=http://host.docker.internal:9092
