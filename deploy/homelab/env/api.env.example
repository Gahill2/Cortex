# Copy to deploy/homelab/env/api.env
# DATABASE_URL is set in docker-compose.yml from Postgres service vars.

NODE_ENV=production
PORT=4000

JWT_SECRET=replace-with-32-char-minimum-secret
JWT_EXPIRES_IN=1h
CORTEX_ENCRYPTION_KEY=replace-with-32-char-minimum-secret

# Browser origins (Tailscale IP, MagicDNS, or LAN). No trailing slash.
CORTEX_FRONTEND_URL=http://127.0.0.1:8080
# Comma-separated UI origins — include every host you open Cortex on (127.0.0.1 and Tailscale IP).
CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080
# Optional fixed OAuth redirect (if unset, redirect follows returnOrigin from Mail connect):
# GOOGLE_REDIRECT_URI=http://127.0.0.1:8080/api/gmail/oauth/callback

# OAuth redirect URIs must match Google/Spotify/etc. console entries and hit your API (homelab: nginx :8080)
# GOOGLE_REDIRECT_URI=http://127.0.0.1:8080/api/gmail/oauth/callback
# CORTEX_FRONTEND_URL=http://127.0.0.1:8080
# SPOTIFY_REDIRECT_URI=http://100.x.x.x:4000/api/spotify/oauth/callback
# MICROSOFT_REDIRECT_URI=http://100.x.x.x:4000/api/microsoft/oauth/callback
# NOTION_REDIRECT_URI=http://100.x.x.x:4000/api/notion/oauth/callback

# Optional integrations (see backend/.env.example)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Email OTP login (pick one) ---
# Real mail (Gmail: use an App Password, not your account password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-16-char-app-password
#
# Self-hosted without SMTP — show code in login UI (local PC / tailnet only):
CORTEX_OTP_DEV_FALLBACK=1

# Obsidian vault (bind-mount host path in docker-compose — see OBSIDIAN_VAULT_HOST_PATH)
OBSIDIAN_VAULT_PATH=/vault
OBSIDIAN_VAULT_NAME=greyhill_brain
OBSIDIAN_AI_LOG_ENABLED=true
OBSIDIAN_USE_CLI=false

# Do not set demo user vars in production homelab unless intentional.
