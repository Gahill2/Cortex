# Copy these lines into deploy/homelab/env/api.env (replace placeholders), then:
#   cd deploy/homelab && docker compose --env-file .env up -d cortex-api
#
# Gmail: create an App Password — https://support.google.com/accounts/answer/185833
# Use the same Google account as SMTP_USER.

CORTEX_OTP_DEV_FALLBACK=0
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
