# Copy to deploy/homelab/.env (compose reads this for substitution)
# cp .env.example .env

# Host paths (relative to deploy/homelab, or absolute e.g. /data/cortex)
CORTEX_DATA_DIR=./data

# NAS data root on this PC (media, cloud, photos — mounted read-only into cortex-api as /nas)
NAS_DATA_ROOT=/home/greyhill/nas-data

# Obsidian vault on host (bind-mounted to /vault in API). Linux homelab:
#   /mnt/cortex/obsidian/greyhill_brain  (see docs/local-storage-and-obsidian.md)
# Windows dev:
#   C:/Users/greyh/Documents/GitHub/greyhill_brain
OBSIDIAN_VAULT_HOST_PATH=/mnt/cortex/obsidian/greyhill_brain

POSTGRES_DB=cortex
POSTGRES_USER=cortex
POSTGRES_PASSWORD=change-me-strong-password
# Host port for Prisma / npm run db:migrate from Windows (do not run a second Postgres on 5432)
POSTGRES_PORT=5432

API_PORT=4000
WEB_PORT=8080

# Baked into cortex-web at build time. Leave empty for Docker homelab (UI calls same-origin /api).
# Set only when API and UI are on different hosts, e.g. http://100.x.x.x:4000/api
# VITE_API_BASE_URL=

# Minutes before PIN lock on idle (baked into cortex-web at build). 0 = disabled. Default 240 on homelab.
# VITE_IDLE_LOCK_MINUTES=240

# Optional: override MagicDNS (e.g. cortex.greyhill.com after Caddy + split DNS)
# CORTEX_PUBLIC_HOST=cortex.greyhill.com

# Auto-deploy webhook (optional — see docs/homelab-auto-deploy.md)
# GITHUB_WEBHOOK_SECRET=
