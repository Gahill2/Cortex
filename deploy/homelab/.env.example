# Copy to deploy/homelab/.env (compose reads this for substitution)
# cp .env.example .env

# Host paths (relative to deploy/homelab, or absolute e.g. /data/cortex)
CORTEX_DATA_DIR=./data

# Obsidian vault — bind-mounted to /vault in the API container.
# Linux homelab hub (ZimaBoard / NAS): set the absolute path on the hub.
# OBSIDIAN_VAULT_HOST_PATH=/mnt/data/greyhill_brain
# Windows dev machine:
# OBSIDIAN_VAULT_HOST_PATH=C:/Users/greyh/Documents/GitHub/greyhill_brain
# Leave unset (commented out) to skip vault mount — API returns empty vault data.
# OBSIDIAN_VAULT_HOST_PATH=

POSTGRES_DB=cortex
POSTGRES_USER=cortex
POSTGRES_PASSWORD=change-me-strong-password
# Host port for Prisma / npm run db:migrate from Windows (do not run a second Postgres on 5432)
POSTGRES_PORT=5432

API_PORT=4000
WEB_PORT=8080

# Baked into cortex-web at build time. Leave empty for Docker homelab (UI calls same-origin /api).
# Set only when API and UI are on different hosts, e.g. http://100.x.x.x:4000/api
# VITE_API_BASE_URL=
