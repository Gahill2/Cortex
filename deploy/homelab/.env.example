# Copy to deploy/homelab/.env (compose reads this for substitution)
# cp .env.example .env

# Host paths (relative to deploy/homelab, or absolute e.g. /data/cortex)
CORTEX_DATA_DIR=./data

POSTGRES_DB=cortex
POSTGRES_USER=cortex
POSTGRES_PASSWORD=change-me-strong-password

API_PORT=4000
WEB_PORT=8080

# Baked into cortex-web at build time — use your Tailscale or LAN URL + /api
# Example: http://100.x.x.x:4000/api or https://cortex-api.your-tailnet.ts.net/api
VITE_API_BASE_URL=http://127.0.0.1:4000/api
