# Static Cortex UI (nginx). Build from repo root via docker-compose.
FROM node:22-slim AS build

WORKDIR /app
COPY frontend/package*.json ./
RUN npm ci

COPY frontend/ ./
ARG VITE_API_BASE_URL=http://127.0.0.1:4000/api
ARG VITE_IDLE_LOCK_MINUTES=240
ARG VITE_APP_VERSION=1.0.0
ARG VITE_BUILD_SHA=unknown
ARG VITE_BUILD_TIME=
ARG VITE_SW_VERSION=
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
ENV VITE_IDLE_LOCK_MINUTES=${VITE_IDLE_LOCK_MINUTES}
ENV VITE_APP_VERSION=${VITE_APP_VERSION}
ENV VITE_BUILD_SHA=${VITE_BUILD_SHA}
ENV VITE_BUILD_TIME=${VITE_BUILD_TIME}
ENV VITE_SW_VERSION=${VITE_SW_VERSION}
RUN npm run build

FROM nginx:1.27-alpine

COPY deploy/homelab/nginx/default.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
