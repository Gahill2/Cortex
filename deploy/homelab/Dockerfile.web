# Static Cortex UI (nginx). Build from repo root via docker-compose.
FROM node:22-slim AS build

WORKDIR /app
COPY frontend/package*.json ./
RUN npm ci

COPY frontend/ ./
ARG VITE_API_BASE_URL=http://127.0.0.1:4000/api
ARG VITE_IDLE_LOCK_MINUTES=240
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
ENV VITE_IDLE_LOCK_MINUTES=${VITE_IDLE_LOCK_MINUTES}
RUN npm run build

FROM nginx:1.27-alpine

COPY deploy/homelab/nginx/default.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
