# NordVPN + Gluetun media stack — copy to .env (never commit .env)
#
# Get Nord **service credentials** (not your login password):
# https://my.nordaccount.com/dashboard/nordvpn/manual-configuration/service-credentials/

NAS_DATA_ROOT=/data

PUID=1000
PGID=1000
TZ=America/New_York

# --- NordVPN via Gluetun ---
# openvpn = easiest (service credentials below)
# wireguard = faster; set WIREGUARD_PRIVATE_KEY instead of OPENVPN_* (see README)
VPN_TYPE=openvpn
OPENVPN_USER=
OPENVPN_PASSWORD=
WIREGUARD_PRIVATE_KEY=
OPENVPN_PROTOCOL=udp
SERVER_COUNTRIES=United States
# Use Nord's P2P-tolerant servers (important for qBittorrent)
SERVER_CATEGORIES=P2P

# LAN + Tailscale subnets so you can open *arr UIs from home/tailnet
FIREWALL_OUTBOUND_SUBNETS=192.168.0.0/16,10.0.0.0/8,100.64.0.0/10,172.16.0.0/12

# Web UI ports (published on the host through gluetun)
QBITTORRENT_PORT=8089
# Web UI (used by npm run media:setup-arr for Radarr/Sonarr client)
QBITTORRENT_USER=admin
QBITTORRENT_PASSWORD=change-me
# After changing password: npm run media:fix-auth && npm run media:setup-arr
PROWLARR_PORT=9696
RADARR_PORT=7878
SONARR_PORT=8989
TORRENTING_PORT=6881

# Usenet (SABnzbd) — not on VPN; default 8082 (Cortex uses 8080, qBittorrent 8089)
SABNZBD_PORT=8082
# Optional: LAN/Tailscale IP *arr apps use to reach SAB (inside Gluetun). Defaults to docker bridge gateway.
# SABNZBD_HOST=172.17.0.1
