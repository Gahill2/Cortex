NAS_DATA_ROOT=/home/greyhill/nas-data

TZ=America/Chicago

# LAN IP of this host (Pi-hole uses it in DNS answers)
PIHOLE_LOCAL_IP=10.0.0.49

# Tailscale IPv4 of this host (`tailscale ip -4`)
PIHOLE_TAILSCALE_IP=100.104.120.29

# Admin UI password — https://100.x.x.x:8090/admin/
PIHOLE_WEBPASSWORD=change-me-pihole-admin

PIHOLE_WEB_PORT=8090
PIHOLE_DNS_PORT=53

# Upstream resolvers (Cloudflare default)
PIHOLE_UPSTREAM_DNS=1.1.1.1;1.0.0.1
