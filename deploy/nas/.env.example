# NAS stack — copy to deploy/nas/.env
# Run: ../../scripts/nas-init-dirs.sh && docker compose --env-file .env up -d

# Host paths (absolute recommended on a NAS)
NAS_DATA_ROOT=/data

# Jellyfin
JELLYFIN_PORT=8096

# Nextcloud (UI port — Cortex uses 8080)
NEXTCLOUD_PORT=8081
NEXTCLOUD_DB_PASSWORD=change-me-nextcloud-db
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change-me-nextcloud-admin

# Immich
IMMICH_PORT=2283
IMMICH_DB_PASSWORD=change-me-immich-db
IMMICH_UPLOAD_LOCATION=${NAS_DATA_ROOT}/photos

# Restic backup (profile: backup)
RESTIC_REPOSITORY=${NAS_DATA_ROOT}/backups/restic
RESTIC_PASSWORD=change-me-restic-encryption-password
# Backup schedule inside container (cron format)
BACKUP_CRON=0 3 * * *
