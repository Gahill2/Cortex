# CIFS shares on another Tailscale PC → Jellyfin second library (/media-remote).
# Copy: cp deploy/nas/.remote-storage.env.example deploy/nas/.remote-storage.env
#
# His PC (zoaurc): enable Windows File Sharing, share the media folders.
# On cortex:
#   npm run nas:remote-storage:list-shares
#   npm run nas:remote-storage:mount
#   npm run nas:jellyfin:library-paths
#   cd deploy/nas && docker compose --env-file .env up -d jellyfin
# Jellyfin → Dashboard → Libraries → Scan all libraries

# Tailscale IP (zoaurc-the-explicator; 100.119.7.128 does not respond on this tailnet)
JELLYFIN_REMOTE_HOST=100.118.7.128

# Share name from: npm run nas:remote-storage:list-shares
# Steve's PC uses share "Users" with movies at Steve/Videos/Movies inside it
JELLYFIN_REMOTE_SMB_SHARE=Users
# Mounted via bind to /mnt/cortex/jellyfin-remote (Jellyfin sees files at /media-remote)
JELLYFIN_REMOTE_SMB_PREFIXPATH=Steve/Videos/Movies

# Optional: separate movies + tv shares
# JELLYFIN_REMOTE_SMB_SHARE_MOVIES=Movies
# JELLYFIN_REMOTE_SMB_SHARE_TV=TV

# Windows account on his machine (must have read access to the share)
JELLYFIN_REMOTE_SMB_USER=
JELLYFIN_REMOTE_SMB_PASSWORD=
JELLYFIN_REMOTE_SMB_DOMAIN=WORKGROUP

# Host mount point (docker maps this → /media-remote)
JELLYFIN_REMOTE_MOUNT=/mnt/cortex/jellyfin-remote

# Jellyfin library paths inside the container
# Share root = movies (use /media-remote/movies only if share contains a movies/ subfolder)
JELLYFIN_REMOTE_MOVIES_PATH=/media-remote
JELLYFIN_REMOTE_TV_PATH=
JELLYFIN_REMOTE_ALWAYS_ADD_PATHS=1
