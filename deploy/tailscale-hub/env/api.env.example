# Copy to deploy/tailscale-hub/env/api.env
# DATABASE_URL is set in docker-compose.yml from Postgres service vars.

# Homelab hub: use development so demo login (ChangeMe123!) is allowed. Use production only with strong secrets and no weak demo vars.
NODE_ENV=development
PORT=4000

JWT_SECRET=replace-with-32-char-minimum-secret
JWT_EXPIRES_IN=1h
CORTEX_ENCRYPTION_KEY=replace-with-32-char-minimum-secret

# Persistent API data directory (canvas assets, vault index, etc). Set by docker-compose.
CORTEX_API_DATA_DIR=/app/data

# Obsidian vault (bind-mounted from host — see OBSIDIAN_VAULT_HOST_PATH in .env)
OBSIDIAN_VAULT_PATH=/vault
OBSIDIAN_VAULT_NAME=greyhill_brain
OBSIDIAN_AI_LOG_ENABLED=true
OBSIDIAN_USE_CLI=false

# Self-hosted without SMTP — show OTP code in login UI (tailnet only, safe for homelab):
CORTEX_OTP_DEV_FALLBACK=1

# Use Tailscale MagicDNS or IP — same on every device that opens the UI.
CORTEX_FRONTEND_URL=http://cortex-zima:8080
CORS_ORIGINS=http://cortex-zima:8080,http://localhost:5173,http://127.0.0.1:5173

# InsForge (optional — storage, MCP). Internal URL is set in compose; override if needed.
# INSFORGE_API_URL=http://insforge:7130
# INSFORGE_ACCESS_API_KEY=ik_...  # from deploy/tailscale-hub/.env ACCESS_API_KEY

# OAuth redirect URIs must use the hub's Tailscale-reachable API URL.
# GOOGLE_REDIRECT_URI=http://cortex-zima:4000/api/gmail/oauth/callback
# SPOTIFY_REDIRECT_URI=http://cortex-zima:4000/api/spotify/oauth/callback
# MICROSOFT_REDIRECT_URI=http://cortex-zima:4000/api/microsoft/oauth/callback
# NOTION_REDIRECT_URI=http://cortex-zima:4000/api/notion/oauth/callback
