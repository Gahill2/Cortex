# Tailscale hub — copy to deploy/tailscale-hub/.env
# cp deploy/tailscale-hub/.env.example deploy/tailscale-hub/.env

# MagicDNS name (preferred) or stable Tailscale IP of THIS machine.
# Example: cortex-zima or cortex-zima.tail12345.ts.net
TAILSCALE_HOST=cortex-zima

# Persistent data on the hub (use an absolute path on the board, e.g. /data/cortex)
CORTEX_DATA_DIR=./data

# --- InsForge / Postgres (shared by Cortex Prisma + InsForge platform) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=cortex
# Published on the tailnet for remote dev (laptops). Standard 5432 on the hub only.
POSTGRES_PORT=5432

POSTGREST_PORT=5430
APP_PORT=7130
AUTH_PORT=7131
DENO_PORT=7133

# InsForge dashboard + API — must be reachable from other tailnet devices (not localhost).
API_BASE_URL=http://cortex-zima:7130
VITE_API_BASE_URL=http://cortex-zima:7130

JWT_SECRET=change-me-use-openssl-rand-base64-32-minimum-length
ENCRYPTION_KEY=

ADMIN_EMAIL=admin@cortex.local
ADMIN_PASSWORD=ChangeMe123!

ACCESS_API_KEY=ik_change_me_minimum_32_characters_long
OPENROUTER_API_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Obsidian vault on the hub — set to the absolute path of greyhill_brain on this machine.
# Example: OBSIDIAN_VAULT_HOST_PATH=/mnt/data/greyhill_brain
# Leave commented out if vault is not on this machine.
# OBSIDIAN_VAULT_HOST_PATH=

# --- Cortex API + web on the hub ---
API_PORT=4000
WEB_PORT=8080

# Baked into cortex-web at build time — Tailscale URL + /api
CORTEX_VITE_API_BASE_URL=http://cortex-zima:4000/api
