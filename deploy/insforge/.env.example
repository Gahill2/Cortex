# InsForge stack for Cortex — copy to deploy/insforge/.env
# cp deploy/insforge/.env.example deploy/insforge/.env
#
# Multi-device / Tailscale (recommended): deploy/tailscale-hub/ on port 5432 — docs/insforge-tailscale.md

# Local-only fallback (port 5433 — no second Postgres on 5432)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cortex
POSTGRES_PORT=5433

POSTGREST_PORT=5430
APP_PORT=7130
AUTH_PORT=7131
DENO_PORT=7133

API_BASE_URL=http://localhost:7130
VITE_API_BASE_URL=http://localhost:7130

# Generate: openssl rand -base64 32
JWT_SECRET=change-me-use-openssl-rand-base64-32-minimum-length
ENCRYPTION_KEY=

ADMIN_EMAIL=admin@cortex.local
ADMIN_PASSWORD=ChangeMe123!

# Optional — InsForge MCP / API from Cortex backend later
ACCESS_API_KEY=ik_change_me_minimum_32_characters_long

OPENROUTER_API_KEY=

# OAuth (optional — can mirror Cortex Google/Microsoft for InsForge dashboard login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
