{
  "name": "backend",
  "version": "1.0.0",
  "description": "Launchpad API server",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "node scripts/dev-start.mjs",
    "dev:lite": "tsx watch src/server.ts",
    "build": "npx prisma generate && npx -p typescript tsc -p tsconfig.json",
    "start": "node scripts/railway-start.mjs",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "mcp:dev": "tsx watch src/mcp/runMcp.ts",
    "mcp:start": "node dist/src/mcp/runMcp.js",
    "sync:env:pull": "tsx scripts/sync-env-firestore.ts pull",
    "sync:env:push": "tsx scripts/sync-env-firestore.ts push"
  },
  "keywords": [
    "launchpad",
    "express",
    "prisma"
  ],
  "author": "launchpad",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@notionhq/client": "^2.3.0",
    "@prisma/client": "^5.22.0",
    "@types/nodemailer": "^8.0.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase-admin": "^13.10.0",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.7",
    "otplib": "^13.4.1",
    "qrcode": "^1.5.4",
    "stripe": "^17.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.1",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
