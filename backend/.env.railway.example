# Paste into Railway → backend service → Variables (Root Directory: backend)
# See docs/railway-deploy.md

NODE_ENV=production
# PORT — do not set; Railway provides PORT automatically

# Railway Postgres: use the **private** DATABASE_URL (service reference), not DATABASE_PUBLIC_URL.
# In the dashboard: New Variable → reference Postgres service → DATABASE_URL
# Or: DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway

# Auth / crypto (generate fresh values; each ≥32 chars)
JWT_SECRET=replace-with-32-char-minimum-secret
JWT_EXPIRES_IN=1h
CORTEX_ENCRYPTION_KEY=replace-with-32-char-minimum-secret

# Browser CORS + OAuth return URLs (your hosted UI origin, no trailing slash)
CORTEX_FRONTEND_URL=https://your-frontend.example.com
CORS_ORIGINS=https://your-frontend.example.com

# Optional: leave demo vars unset in production
# CORTEX_DEMO_USER_EMAIL=
# CORTEX_DEMO_USER_PASSWORD=
# CORTEX_DEMO_USER_PIN=

# API public URL for Google OAuth (must match Google Cloud console)
# GOOGLE_REDIRECT_URI=https://your-api.up.railway.app/api/gmail/oauth/callback

# Add integration keys as needed (ANTHROPIC_API_KEY, STRIPE_*, etc.)
