# Paste into Railway → backend service → Variables (Root Directory: backend)
# End-to-end checklist: docs/cloud-deploy.md  |  Postgres + build: docs/railway-deploy.md
#
# Placeholders:
#   YOUR_VERCEL_URL  = https://your-app.vercel.app
#   YOUR_RAILWAY_URL = https://your-api.up.railway.app

NODE_ENV=production
# PORT — do not set; Railway provides PORT automatically

# Railway Postgres: use the **private** DATABASE_URL (service reference), not DATABASE_PUBLIC_URL.
# DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway

# Auth / crypto (generate fresh values; each ≥32 chars)
JWT_SECRET=replace-with-32-char-minimum-secret
JWT_EXPIRES_IN=1h
CORTEX_ENCRYPTION_KEY=replace-with-32-char-minimum-secret

# Browser CORS + post-OAuth redirects (Vercel UI origin, no trailing slash)
CORTEX_FRONTEND_URL=https://YOUR_VERCEL_URL
CORS_ORIGINS=https://YOUR_VERCEL_URL

# Optional: leave demo vars unset in production
# CORTEX_DEMO_USER_EMAIL=
# CORTEX_DEMO_USER_PASSWORD=
# CORTEX_DEMO_USER_PIN=

# OAuth callbacks — must match provider consoles exactly (API host, not Vercel)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://YOUR_RAILWAY_URL/api/gmail/oauth/callback

# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_REDIRECT_URI=https://YOUR_RAILWAY_URL/api/microsoft/oauth/callback

# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI=https://YOUR_RAILWAY_URL/api/spotify/oauth/callback

# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=
# NOTION_REDIRECT_URI=https://YOUR_RAILWAY_URL/api/notion/oauth/callback

# CANVA_CLIENT_ID=
# CANVA_CLIENT_SECRET=
# CANVA_REDIRECT_URI=https://YOUR_RAILWAY_URL/api/canva/oauth/callback

# Add integration keys as needed (ANTHROPIC_API_KEY, STRIPE_*, etc.)
