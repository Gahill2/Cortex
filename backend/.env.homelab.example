# Use when Docker homelab Postgres is running (npm run server:up).
# Copy to backend/.env and set the password from deploy/homelab/.env (POSTGRES_PASSWORD).

NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://cortex:YOUR_POSTGRES_PASSWORD@127.0.0.1:5432/cortex"

JWT_SECRET=match-deploy-homelab-env-api-env
CORTEX_ENCRYPTION_KEY=match-deploy-homelab-env-api-env

CORTEX_FRONTEND_URL=http://127.0.0.1:8080
CORS_ORIGINS=http://127.0.0.1:8080,http://127.0.0.1:5173

# Do not run npm run dev API while server:up uses port 4000 — use dev:frontend only,
# or server:down then npm run dev.
