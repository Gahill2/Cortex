# Dev on laptop / desktop / phone — shared DB + InsForge on the Tailscale hub.
# Copy to backend/.env (do not commit). Replace cortex-zima with your hub MagicDNS or 100.x.x.x IP.
#
# Hub setup: docs/insforge-tailscale.md

NODE_ENV=development
PORT=4000

# Single Postgres for all devices (hub runs InsForge stack).
DATABASE_URL=postgresql://postgres:YOUR_HUB_POSTGRES_PASSWORD@ghill:5432/launchpad

# InsForge platform (dashboard, storage, MCP) on the same host.
INSFORGE_API_URL=http://cortex-zima:7130
INSFORGE_ACCESS_API_KEY=ik_from_deploy_tailscale_hub_env

JWT_SECRET=replace-with-32-char-minimum-secret
JWT_EXPIRES_IN=1h
CORTEX_ENCRYPTION_KEY=replace-with-32-char-minimum-secret

# Local Vite dev UI — API may still be local or on the hub (see below).
CORTEX_FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Option A — run API locally, DB on hub (typical dev):
#   Use DATABASE_URL above + npm run dev:backend
#
# Option B — API on hub only; frontend dev points at hub:
#   VITE_API_BASE_URL=http://cortex-zima:4000/api  (frontend/.env.local)
#   Do not run dev:backend locally.

CORTEX_DEMO_USER_EMAIL=grey@cortex.local
CORTEX_DEMO_USER_PASSWORD=Ctx-D3m0!Secure8x
CORTEX_DEMO_USER_PIN=1234

OBSIDIAN_VAULT_PATH=
