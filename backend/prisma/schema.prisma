generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String    @id @default(cuid())
  name      String
  users     User[]
  projects  Project[]
  tasks     Task[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  fullName       String
  passwordHash   String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedTasks  Task[] @relation("taskAssignee")
  createdTasks   Task[] @relation("taskCreator")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Project {
  id             String   @id @default(cuid())
  name           String
  description    String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks          Task[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@unique([id, organizationId])
}

model OAuthToken {
  id        String   @id @default(cuid())
  userId    String
  provider  String   // "spotify" | "google" | "notion" | "canva"
  tokens    String   // JSON serialized
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, provider])
}

/// Connected mail inboxes (Gmail OAuth + optional IMAP).
model MailAccount {
  id           String   @id @default(cuid())
  userId       String
  provider     String   // "gmail" | "imap"
  email        String
  label        String?
  isPrimary    Boolean  @default(false)
  tokens       String?  // JSON OAuth credentials (gmail)
  imapHost     String?
  imapPort     Int?
  smtpHost     String?
  smtpPort     Int?
  username     String?
  passwordEnc  String?  // base64-obfuscated for IMAP
  autoOrganize Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@unique([userId, provider, email])
  @@index([userId])
}

/// Per-session user profile (JWT userId) — billing & preferences.
model CortexProfile {
  userId                 String    @id
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  stripePriceId          String?
  subscriptionStatus     String    @default("free")
  stripeCurrentPeriodEnd DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @default(now()) @updatedAt
}

model Task {
  id             String     @id @default(cuid())
  title          String
  description    String?
  status         String     @default("TODO")
  priority       String     @default("MEDIUM")  // LOW | MEDIUM | HIGH
  progressPercent Int       @default(0)         // 0–100 planning progress
  dueDate        DateTime?
  planStart      DateTime?  // optional time block start
  planEnd        DateTime?
  syncToCalendar Boolean    @default(true)
  googleCalendarId String?
  googleEventId  String?
  organizationId String
  projectId      String
  assigneeId     String?
  createdById    String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee       User?        @relation("taskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy      User         @relation("taskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, status])
}

model MailCategory {
  id        String   @id @default(cuid())
  userId    String
  accountId String   @default("")
  messageId String
  category  String   // work | personal | finance | newsletters | social | important | other
  summary   String?  // AI one-liner
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, accountId, messageId])
  @@index([userId, category])
}

/// Per-user UI preferences synced across devices (replaces localStorage).
model UserSettings {
  userId       String   @id
  appearance   String   @default("system") // "light" | "dark" | "system"
  wallpaper    String?  // JSON: { enabled, url, opacity }
  aiTheme      String?  // JSON: { name, gradient, ... }
  weatherCity  String?
  weatherUnits String   @default("metric") // "metric" | "imperial"
  homeGoals    String?  // JSON array
  pinHash      String?  // bcrypt hash for PIN change feature
  canvasLayout String?  // JSON: canvas node positions
  extraJson    String?  // catch-all JSON for future prefs without schema migration
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}
