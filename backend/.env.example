# =========================
# Core runtime
# =========================
NODE_ENV=development
PORT=4000
# SQLite — path is relative to the backend/ folder when running `npm run dev` / `tsx`
DATABASE_URL=file:./dev.db
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =========================
# Auth/session (backend API)
# =========================
JWT_SECRET=replace-with-32-char-minimum-secret
# Electron desktop login (main process sends this header; generate a long random string)
CORTEX_DESKTOP_SECRET=replace-with-long-random-secret
# Comma-separated browser origins allowed to call the API (defaults to localhost dev ports)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
JWT_EXPIRES_IN=1h
CORTEX_ENCRYPTION_KEY=replace-with-32-char-minimum-secret

# OTP email (Gmail: use an App Password, not your normal password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Optional legacy password/PIN login (dev only unless all three are set in production).
# In production, unset these or use strong values — weak defaults are rejected at startup.
CORTEX_DEMO_USER_EMAIL=grey@cortex.local
CORTEX_DEMO_USER_PASSWORD=
CORTEX_DEMO_USER_PIN=

# =========================
# Supabase
# =========================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key-server-only
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# =========================
# Stripe billing
# =========================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# =========================
# AI + rate limiting
# =========================
ANTHROPIC_API_KEY=replace-with-anthropic-api-key
UPSTASH_REDIS_URL=replace-with-upstash-url
UPSTASH_REDIS_TOKEN=replace-with-upstash-token

# =========================
# Module integrations (server-side secrets)
# =========================
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
# Must match an authorized redirect URI in Google Cloud → OAuth client:
GOOGLE_REDIRECT_URI=http://localhost:4000/api/gmail/oauth/callback
# Where the API sends the browser after Gmail consent (your Vite/dev or Tauri-loaded UI):
CORTEX_FRONTEND_URL=http://localhost:5173

SPOTIFY_CLIENT_ID=replace-with-spotify-client-id
SPOTIFY_CLIENT_SECRET=replace-with-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/auth/callback/spotify

STEAM_API_KEY=replace-with-steam-api-key

DISCORD_BOT_TOKEN=replace-with-discord-bot-token
DISCORD_CLIENT_ID=replace-with-discord-client-id
DISCORD_CLIENT_SECRET=replace-with-discord-client-secret

# =========================
# Firebase / Firestore (shared env + online data)
# =========================
FIREBASE_PROJECT_ID=your-firebase-project-id
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
# Or inline (escape newlines as \n):
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
FIRESTORE_ENV_DOC=cortex_config/env
# Set true only when you intend POST /api/firebase/env/* in production
ALLOW_FIREBASE_ENV_SYNC=

# =========================
# Notion / Canva / OpenClaw
# =========================
NOTION_PERSONAL_TOKEN=
NOTION_INTERNAL_TOKEN=
CANVA_CLIENT_ID=
CANVA_APP_ID=
CORTEX_MCP_MODE=local
CORTEX_MCP_HOST=127.0.0.1
CORTEX_MCPPORT=18789

# =========================
# n8n automation
# =========================
# Self-hosted n8n (docker compose service on :5678)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/your-workflow-path
N8N_WEBHOOK_SECRET=
# Base URL for n8n HTTP Request nodes (Docker → host Cortex API)
CORTEX_API_URL=http://host.docker.internal:4000/api

# =========================
# Local desktop integration
# =========================
# One vault (legacy) or several paths separated by ; on Windows, , on Unix
OBSIDIAN_VAULT_PATH=C:\Users\greyh\Documents\GitHub\greyhill_brain
OBSIDIAN_VAULT_PATHS=

# Agentmemory — persistent memory for coding agents (https://github.com/rohitg00/agentmemory)
# Run: npm run dev:memory  (API http://127.0.0.1:3111, viewer http://127.0.0.1:3113)
AGENTMEMORY_URL=http://127.0.0.1:3111
AGENTMEMORY_SECRET=
# Same project id on laptop, desktop, and VPS so memory stays unified
AGENTMEMORY_PROJECT=cortex
AGENTMEMORY_AUTO_REMEMBER=false
CORTEX_ENABLE_VAULT_WATCHER=false
CORTEX_MANAGE_AGENTMEMORY=false
