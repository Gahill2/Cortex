# =========================
# Core runtime
# =========================
NODE_ENV=development
PORT=4000
# Prisma (PostgreSQL) — single InsForge hub (docs/insforge-tailscale.md)
# On the hub machine:
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/launchpad"
# Other Tailscale devices (copy backend/.env.tailscale.example):
# DATABASE_URL="postgresql://postgres:PASSWORD@ghill:5432/launchpad"

# InsForge platform API (after npm run hub:up — ports 7130 / 7131)
# INSFORGE_API_URL=http://127.0.0.1:7130
# INSFORGE_ACCESS_API_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =========================
# Auth/session (backend API)
# =========================
JWT_SECRET=replace-with-32-char-minimum-secret
JWT_EXPIRES_IN=1h
CORTEX_ENCRYPTION_KEY=replace-with-32-char-minimum-secret

# Local demo/dev bootstrap only (non-production placeholders).
CORTEX_DEMO_USER_EMAIL=grey@cortex.local
CORTEX_DEMO_USER_PASSWORD=Ctx-D3m0!Secure8x
CORTEX_DEMO_USER_PIN=1234

# =========================
# AI + rate limiting
# =========================
# Claude (Anthropic) — chat provider "claude"
ANTHROPIC_API_KEY=replace-with-anthropic-api-key
# ChatGPT (OpenAI API) — chat provider "openai"
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com
# Ollama (local) — chat provider "ollama"
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
UPSTASH_REDIS_URL=replace-with-upstash-url
UPSTASH_REDIS_TOKEN=replace-with-upstash-token

# =========================
# Module integrations (server-side secrets)
# =========================
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
# Must match an authorized redirect URI in Google Cloud → OAuth client:
GOOGLE_REDIRECT_URI=http://localhost:4000/api/gmail/oauth/callback
# Where the API sends the browser after Gmail consent (your Vite/dev or Tauri-loaded UI):
CORTEX_FRONTEND_URL=http://localhost:5173

SPOTIFY_CLIENT_ID=replace-with-spotify-client-id
SPOTIFY_CLIENT_SECRET=replace-with-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://localhost:4000/api/spotify/oauth/callback

STEAM_API_KEY=replace-with-steam-api-key

DISCORD_BOT_TOKEN=replace-with-discord-bot-token
DISCORD_CLIENT_ID=replace-with-discord-client-id
DISCORD_CLIENT_SECRET=replace-with-discord-client-secret

# =========================
# Local desktop integration
# =========================
# Leave empty in dev to save RAM (no vault file watcher). See docs/dev-resources.md
OBSIDIAN_VAULT_PATH=
# OBSIDIAN_VAULT_PATH=C:\Users\you\vault

# =========================
# Notion (https://developers.notion.com/docs/getting-started)
# =========================
 Option A — Internal integration (single workspace; share pages with the integration in Notion):
NOTION_INTERNAL_TOKEN=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

# Option B — Public OAuth (per-user; register at https://www.notion.so/my-integrations):
# NOTION_CLIENT_ID=...
# NOTION_CLIENT_SECRET=...
# NOTION_REDIRECT_URI=http://localhost:4000/api/notion/oauth/callback
# For Electron deep links, use NOTION_REDIRECT_URI=cortex://oauth/notion (also register in Notion).
#
# The Notion CLI from https://ntn.dev does not support Windows; Cortex uses the HTTP API directly.

# =========================
# Cortex MCP (Streamable HTTP, separate process — NOT the main API port)
# =========================
# Local only (this PC):
#   CORTEX_MCP_MODE=local
# Phone + Tailscale (bind all interfaces; Host/CORS allow Tailscale CGNAT + MagicDNS):
#   CORTEX_MCP_MODE=tailscale
#   CORTEX_MCP_HOST=0.0.0.0
#   CORTEX_MCP_PORT=3001
# Optional extra hostnames (comma-separated, no ports), e.g. your PC MagicDNS name:
#   CORTEX_MCP_ALLOWED_HOSTS=my-pc.tail123456.ts.net
# Add your Vite URL if you open Cortex from the phone over Tailscale:
#   CORTEX_FRONTEND_URL=http://100.x.x.x:5173
CORTEX_MCP_MODE=local
CORTEX_MCP_PORT=3001
CORTEX_MCP_HOST=
CORTEX_MCP_ALLOWED_HOSTS=
CORTEX_MCP_ALLOW_TAILSCALE_CIDR=1
CORTEX_MCP_ALLOW_TAILSCALE_NAMES=1
CORTEX_MCP_STRICT_CORS=0
CORTEX_MCP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORTEX_MCP_NOTES_PATH=

# =========================
# Canva (https://www.canva.dev/docs/apps/ + https://www.canva.dev/docs/connect/)
# =========================
# Apps SDK / CLI scaffold (from developer portal or `npm run canva -- apps create`):
# CANVA_APP_ID=
# CANVA_APP_ORIGIN=https://app-xxxx.canva-apps.com
# CANVA_HMR_ENABLED=false
#
# Connect API OAuth (client secret must stay on this server only):
# CANVA_CLIENT_ID=OC-...
# CANVA_CLIENT_SECRET=cnvca...
# Register this exact redirect in the Connect integration → Authentication:
# CANVA_REDIRECT_URI=http://localhost:4000/api/canva/oauth/callback
# Space-separated scopes enabled for the integration (default below if unset):
# CANVA_CONNECT_SCOPES=design:meta:read

# =========================
# Firebase / Firestore (shared env + future online data)
# =========================
# See docs/firebase-setup.md
# FIREBASE_PROJECT_ID=your-firebase-project-id
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
# FIRESTORE_ENV_DOC=cortex_config/env
# Or inline (escape newlines as \n):
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
# ALLOW_FIREBASE_ENV_SYNC=true
# FIREBASE_USE_APPLICATION_DEFAULT=true

# =========================
# Railway production (API service — see docs/railway-deploy.md)
# =========================
# Copy backend/.env.railway.example into the Railway dashboard.
# NODE_ENV=production
# DATABASE_URL=${{Postgres.DATABASE_URL}}  (private URL — not DATABASE_PUBLIC_URL)
# JWT_SECRET=...
# CORTEX_ENCRYPTION_KEY=...
# CORTEX_FRONTEND_URL=https://your-ui.example.com
# CORS_ORIGINS=https://your-ui.example.com
# PORT is set by Railway — do not override unless you know why.
