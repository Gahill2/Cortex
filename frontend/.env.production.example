# Homelab Docker production build (deploy/homelab/docker-compose.yml → cortex-web).
# Set in deploy/homelab/.env — baked in at docker compose build time.
#
# Recommended: leave VITE_API_BASE_URL unset so the UI uses same-origin /api via nginx.
# See docs/homelab-deploy.md

# Only for split API/UI hosts (uncommon on homelab):
# VITE_API_BASE_URL=http://100.x.x.x:4000/api

# Optional — Canva Apps SDK display hints in Settings UI
# VITE_CANVA_APP_ID=

# Legacy cloud split deploy (Vercel + Railway): docs/cloud-deploy.md
# VITE_API_BASE_URL=https://YOUR_RAILWAY_URL/api
