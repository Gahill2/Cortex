# Frontend dev against API on the Tailscale hub (optional).
# Copy to frontend/.env.local — replace cortex-zima with hub MagicDNS or 100.x.x.x.
#
# If unset, dev mode still auto-uses the same host as the Vite tab for :4000 when you open
# http://<tailscale-ip>:5173 (see frontend/src/api/client.ts).

VITE_API_BASE_URL=http://cortex-zima:4000/api
