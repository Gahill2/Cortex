# =============================================================================
# Local development (default)
# =============================================================================
# Omit VITE_API_BASE_URL — the client uses http://localhost:4000/api, or the
# same host as Vite on your LAN (see frontend/src/api/client.ts).

# Optional: Canva app ID from https://www.canva.com/developers/
# VITE_CANVA_APP_ID=

# =============================================================================
# Split deploy: Vercel UI + Railway API (production)
# =============================================================================
# Set these in Vercel → Project → Settings → Environment Variables → Production.
# Do NOT rely on a local .env for production — values are baked in at build time.
#
# YOUR_VERCEL_URL  = https://your-app.vercel.app  (UI — set on Railway for CORS)
# YOUR_RAILWAY_URL = https://your-api.up.railway.app  (API — no /api suffix)
#
# VITE_API_BASE_URL must end with /api:
# VITE_API_BASE_URL=https://your-api.up.railway.app/api
#
# See docs/cloud-deploy.md and frontend/.env.production.example
