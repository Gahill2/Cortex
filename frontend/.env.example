# API base URL (must end with /api). Baked in at `npm run build` for production.
# Local dev: omit — client uses http://localhost:4000/api (or same host as Vite on LAN).
# Railway / split deploy example:
# VITE_API_BASE_URL=https://your-api-service.up.railway.app/api

# Optional: Canva app ID from https://www.canva.com/developers/ (display / future client-side wiring)
# Copy to .env locally — do not commit real values.
# VITE_CANVA_APP_ID=
