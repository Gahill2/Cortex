# =============================================================================
# Local development (default)
# =============================================================================
# Omit VITE_API_BASE_URL — the client uses same-origin /api (Vite proxies to :4000).
# See frontend/src/api/client.ts.

# Optional: Canva app ID from https://www.canva.com/developers/
# VITE_CANVA_APP_ID=

# =============================================================================
# Homelab Docker production (cortex-web build)
# =============================================================================
# Set in deploy/homelab/.env for docker compose build args.
# Leave VITE_API_BASE_URL empty for same-origin /api via nginx (recommended).
# Only set when API and UI are on different hosts:
# VITE_API_BASE_URL=http://100.x.x.x:4000/api
#
# See docs/homelab-deploy.md and deploy/homelab/.env.example

# =============================================================================
# Legacy: Vercel UI + Railway API (optional cloud deploy)
# =============================================================================
# See docs/cloud-deploy.md — not used for homelab Docker.
# VITE_API_BASE_URL=https://your-api.up.railway.app/api
