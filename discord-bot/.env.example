# https://discord.com/developers/applications → General → Application ID
DISCORD_APPLICATION_ID=
# Bot → Token
DISCORD_BOT_TOKEN=

# Right-click server → Copy Server ID
DISCORD_GUILD_ID=

# Right-click #setup → Copy Channel ID (welcome + /wpp-links target)
DISCORD_SETUP_CHANNEL_ID=

# Comma-separated role IDs that can start/stop containers (or leave empty and use DISCORD_ADMIN_USER_IDS)
DISCORD_ADMIN_ROLE_IDS=
# Comma-separated Discord user IDs (owners) — always admin
DISCORD_ADMIN_USER_IDS=

# Homelab deploy listener (same token as deploy/homelab/.env CORTEX_DEPLOY_TOKEN)
HOMELAB_DEPLOY_LISTENER_URL=http://127.0.0.1:9092
CORTEX_DEPLOY_TOKEN=

# Public service health probes (Tailscale / Pi-hole names)
WPP_JELLYFIN_HEALTH_URL=http://127.0.0.1:8096/health
WPP_NEXTCLOUD_HEALTH_URL=http://127.0.0.1:8081/status.php
WPP_IMMICH_HEALTH_URL=http://127.0.0.1:2283/api/server/ping

# Friendly links shown to witnesses
WPP_LINK_JELLYFIN=http://jellyfin.cortex:8096
WPP_LINK_NEXTCLOUD=http://cloud.cortex:8081
WPP_LINK_IMMICH=http://photos.cortex:2283

# Joey's movies mount (optional status line)
WPP_JOEY_MOUNT=/mnt/cortex/jellyfin-remote
